rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isFamilyMember(familyId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isFamilyAdmin(familyId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isOwner(userId);

      // Allow read for family members (for member lists, etc.)
      allow read: if isAuthenticated();
    }

    // Families collection
    match /families/{familyId} {
      // Family members can read family data
      allow read: if isFamilyMember(familyId);

      // Only family admins can create/update/delete families
      allow create: if isAuthenticated();
      allow update, delete: if isFamilyAdmin(familyId);
    }

    // Family members subcollection
    match /families/{familyId}/members/{memberId} {
      // Family members can read member data
      allow read: if isFamilyMember(familyId);

      // Users can update their own member data
      allow write: if isOwner(memberId) && isFamilyMember(familyId);
    }

    // Family tasks collection (app uses `family_tasks`)
    match /family_tasks/{taskId} {
      // Helper: familyId for this task (resource is available for get/list)
      function taskFamilyId() {
        return resource.data.familyId;
      }

      // Helper: familyId of the authenticated user (uses users/{uid}.familyId maintained by the app)
      function userFamilyId() {
        return isAuthenticated() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId : null;
      }

      // READ: allow if user is authenticated, belongs to the family, and either the task is not private
      // or the user is the creator of the task. This enforces that private tasks are only readable by their creator.
      allow read: if isAuthenticated()
                  && userFamilyId() == taskFamilyId()
                  && (resource.data.private != true || resource.data.createdBy == request.auth.uid);

  // CREATE: authenticated family member can create a task for their family and must set createdBy == request.auth.uid
  // Stronger validation: enforce types for common fields to avoid regressions from clients.
  allow create: if isAuthenticated()
        && request.resource.data.familyId == userFamilyId()
        && request.resource.data.createdBy == request.auth.uid
        // createdAt must be a timestamp
        && request.resource.data.createdAt is timestamp
        // private must be boolean if present
        && (!('private' in request.resource.data) || request.resource.data.private is bool)
        // repeatDays if present should be a list (finer validation handled server-side)
        && (!('repeatDays' in request.resource.data) || request.resource.data.repeatDays is list);

  // UPDATE: only the creator may update their task. Prevent changing ownership/family and validate types.
  allow update: if isAuthenticated()
         && resource.data.createdBy == request.auth.uid
         // Prevent changing who created the task or which family it belongs to
         && request.resource.data.createdBy == resource.data.createdBy
         && request.resource.data.familyId == resource.data.familyId
         // private must be boolean if present
         && (!('private' in request.resource.data) || request.resource.data.private is bool)
         // repeatDays if present should be a list
         && (!('repeatDays' in request.resource.data) || request.resource.data.repeatDays is list)
         // updatedAt if present must be a timestamp
         && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);

  // DELETE: only the creator may delete their task
  allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Approvals (if approvals are stored as a top-level collection or subcollection under family_tasks)
    // If your app stores approvals as a subcollection under family_tasks, allow family members to read/write
    // approvals only if they belong to the same family. If approvals are stored elsewhere, adjust accordingly.
    match /family_tasks/{taskId}/approvals/{approvalId} {
      function taskFamilyId() {
        return get(/databases/$(database)/documents/family_tasks/$(taskId)).data.familyId;
      }

      allow read, write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == taskFamilyId();
    }

    // Categories collection (if used globally)
    match /categories/{categoryId} {
      // Allow read for authenticated users
      allow read: if isAuthenticated();

      // Allow write for authenticated users (categories might be shared)
      allow write: if isAuthenticated();
    }

    // Default deny for any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}