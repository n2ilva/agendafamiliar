rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if false; // nunca apagamos perfis diretamente
    }

    match /categories/{catId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;

      allow update: if isSignedIn() && (
        // Admin pode sempre atualizar
        isAdmin() ||
        // Kid pode alterar de pending -> pending_approval na própria tarefa
        (
          request.resource.data.status == 'pending_approval' &&
          resource.data.status == 'pending' &&
          resource.data.createdBy == request.auth.uid
        ) ||
        // Kid pode reverter pending_approval -> pending se foi ele quem criou
        (
          request.resource.data.status == 'pending' &&
          resource.data.status == 'pending_approval' &&
          resource.data.createdBy == request.auth.uid
        )
      );

      allow delete: if false; // não permitimos exclusão (poderia ser lógico)
    }
  }
}
