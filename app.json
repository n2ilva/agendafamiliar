{
  "expo": {
    "name": "agenda-familiar",
    "slug": "agenda-familiar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android-chrome-192x192.png",
    "userInterfaceStyle": "light",
    "scheme": "com.n2ilva.agendafamiliar",
    "splash": {
      "image": "./assets/android-chrome-192x192.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.n2ilva.agendafamiliar",
      "supportsTablet": true
    },
    "android": {
      "package": "com.n2ilva.agendafamiliar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-chrome-512x512.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.ico"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://maven.google.com/"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0940c39a-6af9-4cbc-ab0c-b955e72cdab8"
      }
    }
  }
}
