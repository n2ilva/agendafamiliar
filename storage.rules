rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Estrutura esperada: profilePictures/{userId}/{filename}
    match /profilePictures/{userId}/{allPaths=**} {
      // Todos autenticados podem ler qualquer foto de perfil
      allow read: if request.auth != null;
      // Somente o próprio usuário pode enviar/atualizar
      allow write: if request.auth != null && request.auth.uid == userId;
      // Somente o próprio usuário pode deletar
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Demais caminhos bloqueados por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}